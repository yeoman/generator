{
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["dist", "node_modules", "**/templates/**", "test/fixtures", "coverage"],
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
